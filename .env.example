# Copy this file to .env (or set these as real environment variables on
# your host) and fill in real values before running the portal in
# production. All of these are OPTIONAL — sensible (but insecure)
# defaults are used if you don't set them, purely so the app runs on
# the very first try.

# Session cookie signing secret — use a long random string in production.
SESSION_SECRET=change-this-to-a-long-random-string

# Set to "production" when deployed behind HTTPS so login cookies are
# marked Secure. Leave unset for local http://localhost testing.
# NODE_ENV=production

# Port the server listens on (default 3000)
# PORT=3000

# ── The 3 portal accounts (only used the very first time the server
#    starts, when the database has no users yet) ──
USER1_USERNAME=admin
USER1_PASSWORD=change-me-1
USER1_NAME=Admin

USER2_USERNAME=user2
USER2_PASSWORD=change-me-2
USER2_NAME=User Two

USER3_USERNAME=user3
USER3_PASSWORD=change-me-3
USER3_NAME=User Three
